{
  "name": "product-catalog-demo",
  "version": "1.0.0",
  "description": "Product catalog demo — simulates missing DB index performance issues for SWO SaaS observability",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:instrumented": "node --import solarwinds-apm src/server.js",
